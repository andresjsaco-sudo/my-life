<!-- Minimal top nav -->
<header class="site-header" role="banner">
  <a href="#hero" class="site-logo">{{name}}</a>
  <button type="button" class="nav-toggle" aria-label="Open menu" aria-expanded="false">
    <span class="nav-toggle-bar"></span>
    <span class="nav-toggle-bar"></span>
    <span class="nav-toggle-bar"></span>
  </button>
  <nav class="site-nav" role="navigation" aria-label="Main">
    <a href="#about">About</a>
    <a href="#skills">Skills</a>
    <a href="#projects">Projects</a>
    <a href="#experience">Experience</a>
    <a href="#contact">Contact</a>
    <label class="theme-toggle" aria-label="Toggle theme">
      <input type="checkbox" id="theme-toggle" class="theme-toggle-input" />
      <span class="theme-toggle-slider">
        <span class="theme-toggle-icon theme-sun" aria-hidden="true">☀</span>
        <span class="theme-toggle-icon theme-moon" aria-hidden="true">◐</span>
      </span>
    </label>
  </nav>
</header>

<main>
  <!-- Hero: centered, bold -->
  <section id="hero" class="hero" aria-label="Introduction">
    <div class="hero-inner">
      <p class="hero-meta">{{role}} · {{location}}</p>
      <h1 class="hero-title">{{name}}</h1>
      <p class="hero-tagline"><span class="typewriter-wrap"></span><span class="cursor"></span></p>
      <p class="hero-quote">"The most interesting signals are the ones hiding just below the threshold of perception."</p>
      <p class="hero-desc">
        Electronic engineering student at {{university}}, specializing in instrumentation,
        IoT sensor systems, and machine learning. I design from the transistor up.
      </p>
      <div class="hero-actions">
        <a href="#projects" class="btn btn-primary">View Projects</a>
        <a href="#contact" class="btn btn-ghost">Get in Touch</a>
      </div>
      <ul class="hero-stats" aria-label="Highlights">
        {{#each stats}}
        <li><strong>{{number}}{{suffix}}</strong> {{label}}</li>
        {{/each}}
      </ul>
    </div>
  </section>

  <!-- About: photo + text -->
  <section id="about" class="section about">
    <div class="section-inner">
      <h2 class="section-title">About</h2>
      <div class="about-layout">
        <div class="about-photo-wrap reveal">
          <img src="/images/profile.jpg" alt="{{name}}" class="about-photo" onerror="this.style.display='none'" />
        </div>
        <div class="about-content reveal">
          {{#each bio}}
          <p>{{{this}}}</p>
          {{/each}}
          <ul class="about-tags">
            {{#each tags}}
            <li><span class="pill pill-{{accent}}">{{label}}</span></li>
            {{/each}}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Skills: compact rows -->
  <section id="skills" class="section skills">
    <div class="section-inner">
      <h2 class="section-title">Skills</h2>
      <div class="skills-list">
        {{#each skills}}
        <article class="skill-block reveal">
          <div class="skill-head">
            <span class="skill-icon">{{{icon}}}</span>
            <h3 class="skill-title">{{{title}}}</h3>
          </div>
          <ul class="skill-pills">
            {{#each pills}}
            <li class="skill-pill">{{{this}}}</li>
            {{/each}}
          </ul>
        </article>
        {{/each}}
      </div>
    </div>
  </section>

  <!-- Projects: cards -->
  <section id="projects" class="section projects">
    <div class="section-inner">
      <h2 class="section-title">Projects</h2>
      <div class="project-list">
        {{#each projects}}
        <article class="project-card {{#if featured}}project-featured{{/if}} reveal">
          <span class="project-type">{{type}}</span>
          <h3 class="project-title">{{title}}</h3>
          <div class="project-desc">{{{description}}}</div>
          <ul class="project-tags">
            {{#each tags}}
            <li><span class="tag">{{this}}</span></li>
            {{/each}}
          </ul>
        </article>
        {{/each}}
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section id="certifications" class="section certs">
    <div class="section-inner">
      <h2 class="section-title">Certifications</h2>
      <ul class="timeline-list">
        {{#each certifications}}
        <li class="timeline-item reveal">
          <span class="timeline-meta">{{org}}</span>
          <div class="timeline-content">
            <h3 class="timeline-title">{{title}}</h3>
            <p class="timeline-org">{{issuer}}</p>
            <p class="timeline-desc">{{desc}}</p>
          </div>
        </li>
        {{/each}}
      </ul>
    </div>
  </section>

  <!-- Experience -->
  <section id="experience" class="section experience">
    <div class="section-inner">
      <h2 class="section-title">Experience</h2>
      <ul class="timeline-list">
        {{#each experience}}
        <li class="timeline-item reveal">
          <span class="timeline-meta">{{period}}</span>
          <div class="timeline-content">
            <h3 class="timeline-title">{{title}}</h3>
            <p class="timeline-org">{{org}}</p>
            <div class="timeline-desc">{{{desc}}}</div>
          </div>
        </li>
        {{/each}}
      </ul>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="section contact">
    <div class="section-inner contact-inner">
      <h2 class="section-title">Contact</h2>
      <p class="contact-lead">Let's build something that matters — sensor systems, research, or a conversation about instrumentation, IoT, or Formula 1.</p>
      <div class="contact-actions">
        <a href="mailto:{{contact.email}}" class="btn btn-primary">Email me</a>
        <a href="{{contact.linkedin}}" target="_blank" rel="noopener noreferrer" class="btn btn-ghost">LinkedIn</a>
      </div>
      <p class="contact-location">📍 {{contact.location}}</p>
    </div>
  </section>
</main>

<footer class="site-footer">
  <a href="#hero" class="back-top" aria-label="Back to top">↑</a>
  <p>© 2025 {{name}}</p>
</footer>
